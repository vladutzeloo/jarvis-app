# JARVIS local — environment template.
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit real keys.
#
# To use:
#   cp .env.example .env
#   # then edit .env with your secrets
#
# Mirrors the convention in the vault repo (vladutzeloo/own-jarvis).
# The local Tauri app reads this file at startup via the Rust side,
# so values here never reach the webview as plain JS strings.

# ──────────────────────────────────────────────────────────────────────────────
# NVIDIA API (build.nvidia.com)
# ──────────────────────────────────────────────────────────────────────────────
# Get a key: https://build.nvidia.com/  →  sign in  →  "Get API Key"
# Used by the Chat tab when you pick an NVIDIA-served model.
NVIDIA_API_KEY=

# Default endpoint and model. Override per call as needed.
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_DEFAULT_MODEL=meta/llama-3.1-70b-instruct

# ──────────────────────────────────────────────────────────────────────────────
# own-jarvis vault (brain)
# ──────────────────────────────────────────────────────────────────────────────
# Absolute or relative path to your local clone of vladutzeloo/own-jarvis.
# Leave blank to disable vault features.
JARVIS_VAULT_PATH=

# ──────────────────────────────────────────────────────────────────────────────
# Tavily web search
# ──────────────────────────────────────────────────────────────────────────────
# Get a key: https://tavily.com  →  sign in  →  "API Keys"
# Powers the 🌐 toggle in the chat toolbar. When set, Research mode pulls
# fresh web hits alongside vault notes; when blank, web search is silently
# skipped and Research mode keeps working off the vault only.
TAVILY_API_KEY=
